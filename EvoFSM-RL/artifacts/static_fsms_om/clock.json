    "strategies": [
      {
        "name": "ADD_WORLD_CLOCK_CITY",
        "preconditions": "App open, on Clock tab",
        "steps": [
          "click fab + button",
          "type city name in search",
          "if results don't appear, tap search bar to refocus or tap keyboard search",
          "click matching city in results"
        ],
        "success_signal": "City card appears below local time on Clock tab",
        "fallback": "Clear search with X, retype; or tap search field to bring back keyboard"
      },
      {
        "name": "CREATE_ALARM",
        "preconditions": "On Alarm tab",
        "steps": [
          "click fab + button",
          "tap keyboard icon to switch to keypad",
          "type hour",
          "tap minute field",
          "type minute",
          "click OK",
          "toggle day-of-week circles for repeat days",
          "click Add label, type label, click OK"
        ],
        "success_signal": "New alarm appears in list with correct time, days, and label, toggle on",
        "fallback": "Tap the time on expanded card to reopen picker if time was wrong"
      },
      {
        "name": "EDIT_EXISTING_ALARM",
        "preconditions": "On Alarm tab with target alarm visible",
        "steps": [
          "click expand arrow on alarm card",
          "tap time display to change time if needed",
          "toggle day circles as needed",
          "click Add label and update label",
          "toggle Vibrate as needed"
        ],
        "success_signal": "Card shows updated values",
        "fallback": ""
      },
      {
        "name": "DELETE_ALARM",
        "preconditions": "On Alarm tab",
        "steps": [
          "click expand arrow on target alarm",
          "scroll if needed",
          "click Delete (trash icon)"
        ],
        "success_signal": "Alarm removed; 'Alarm deleted' toast",
        "fallback": ""
      },
      {
        "name": "SET_AND_START_TIMER",
        "preconditions": "On Timer tab",
        "steps": [
          "tap digits on numeric keypad (right-to-left fills s, m, h)",
          "use 00 shortcut where helpful",
          "click play button"
        ],
        "success_signal": "Countdown ring active with chosen duration",
        "fallback": "If wrong duration, edit before pressing play"
      },
      {
        "name": "RENAME_RUNNING_TIMER",
        "preconditions": "Timer running",
        "steps": [
          "tap default timer label (e.g., '5m Timer')",
          "type new label",
          "click OK"
        ],
        "success_signal": "Timer card shows new label",
        "fallback": ""
      },
      {
        "name": "STOPWATCH_LAP_FLOW",
        "preconditions": "On Stopwatch tab",
        "steps": [
          "click play",
          "wait until desired elapsed time",
          "click lap button to record each lap",
          "click pause when done",
          "click reset to clear"
        ],
        "success_signal": "Lap entries listed below; reset returns to 00 00",
        "fallback": "If accidentally paused, press play to resume before lapping"
      },
      {
        "name": "CONFIGURE_BEDTIME_SCHEDULE",
        "preconditions": "Bedtime tab, not configured",
        "steps": [
          "click Get started",
          "tap wake-up time, set via clock face or keypad, OK",
          "toggle weekday circles",
          "toggle Sunrise Alarm / Vibrate as needed",
          "click Next",
          "tap bedtime, set time, OK",
          "ensure day selection",
          "click Done"
        ],
        "success_signal": "Bedtime dashboard shows schedule with BEDTIME/WAKE-UP and 'Next alarm on...'",
        "fallback": ""
      },
      {
        "name": "SEND_FEEDBACK_WITH_LOGS",
        "preconditions": "Clock app open",
        "steps": [
          "click three-dot menu",
          "click Send feedback",
          "click Allow one-time access in permission dialog",
          "tap text field and type feedback message",
          "dismiss keyboard with Back to see checkboxes",
          "check System logs / uncheck Screenshot as required",
          "click send (paper plane)"
        ],
        "success_signal": "Returns to Clock main interface (form closed)",
        "fallback": "Re-open menu and try again if menu dismissed"
      },
      {
        "name": "EDIT_FEEDBACK_SCREENSHOT",
        "preconditions": "On Send Feedback with screenshot attachment",
        "steps": [
          "click Screenshot card / 'Highlight or hide info'",
          "click GOT IT on intro overlay",
          "select highlight (yellow) or redact (black) tool",
          "swipe across target area",
          "click checkmark to save"
        ],
        "success_signal": "Returns to feedback form with edited screenshot",
        "fallback": "Use undo if mistake"
      },
      {
        "name": "QUERY_ALARM_INFO",
        "preconditions": "App open",
        "steps": [
          "navigate to Alarm tab",
          "read alarm cards for time, days, label, toggle state"
        ],
        "success_signal": "Information visible on screen",
        "fallback": ""
      },
      {
        "name": "QUERY_CITY_TIME",
        "preconditions": "App open",
        "steps": [
          "go to Clock tab",
          "click + and search city",
          "select result",
          "read time shown on city card"
        ],
        "success_signal": "City time displayed",
        "fallback": ""
      }
    ],
    "dead_ends": [
      {
        "state": "city_search",
        "failed_action": "type city + tap keyboard search",
        "note": "Search may not populate results; remedy is to tap the search field again to refocus or clear with X and retype"
      },
      {
        "state": "city_search",
        "failed_action": "search while offline",
        "note": "Only limited cities shown; need network for full results"
      },
      {
        "state": "world_clock_tab",
        "failed_action": "click(fab_plus) intending alarm",
        "note": "FAB on Clock tab adds a city, not an alarm; must switch to Alarm tab first"
      },
      {
        "state": "time_picker_keypad",
        "failed_action": "type minute without selecting minute field",
