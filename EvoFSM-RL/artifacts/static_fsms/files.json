    "strategies": [
      {
        "name": "DELETE_FILE_IN_FOLDER",
        "preconditions": "home_screen; know folder path and filename",
        "steps": [
          "open_app('Files by Google') -> files_folder_view",
          "click('Show roots') -> files_roots",
          "click(storage root, e.g. 'sdk_gphone64_x86_64') -> files_folder_view",
          "click(target subfolder, e.g. 'Notifications'/'Alarms'/'Downloads')",
          "scroll_down if file not visible",
          "long_press(target file) -> files_selection_mode",
          "click('Delete') -> delete_confirm_dialog",
          "click('OK') -> file removed"
        ],
        "success_signal": "'Deleting 1 item.' toast and file no longer listed in folder",
        "fallback": "If file not found in assumed folder, use Show roots and try the correct top-level folder; use Search icon by filename"
      },
      {
        "name": "MOVE_FILE_BETWEEN_FOLDERS",
        "preconditions": "home_screen; know source folder, destination folder, filename",
        "steps": [
          "open_app('Files by Google')",
          "click('Show roots') and navigate into storage root (e.g. 'sdk_gphone64_x86_64')",
          "click(source subfolder)",
          "scroll_down until file visible",
          "long_press(target file) -> files_selection_mode",
          "click('More options') -> files_context_menu",
          "click('Move to…') -> files_move_destination_picker",
          "In destination picker: click('Show roots') if needed, click(storage root), click(destination subfolder) so header shows destination",
          "click('MOVE') to confirm"
        ],
        "success_signal": "'Moving 1 item.' toast, returned to source folder without the file; file appears in destination folder",
        "fallback": "If picker lands in Downloads, do NOT press MOVE there; navigate via Show roots -> storage root -> correct destination folder before confirming"
      }
    ],
    "dead_ends": [
      {
        "state": "settings_storage",
        "failed_action": "click('Free up space') expecting Files app",
        "note": "Free up space leads to cleanup screen (Nothing to remove / Remove items for apps), not the file browser. Repeatedly clicking loops between settings_storage <-> storage_cleanup. Use open_app('Files by Google') instead."
      },
      {
        "state": "files_folder_view(Downloads)",
        "failed_action": "repeatedly click('Images') to reach Pictures folder",
        "note": "Category chips filter the current folder; they do not navigate to the Pictures directory. Use Show roots -> storage root -> Pictures."
      },
      {
        "state": "files_move_destination_picker(Downloads)",
        "failed_action": "click('MOVE') while picker still shows default Downloads",
        "note": "Confirms move to Downloads instead of intended destination. Navigate picker to the correct destination folder before pressing MOVE."
      },
      {
        "state": "files_context_menu",
        "failed_action": "click('Get info') thinking it is 'Move to…'",
        "note": "Wrong menu entry selected; need to read labels and pick 'Move to…'."
